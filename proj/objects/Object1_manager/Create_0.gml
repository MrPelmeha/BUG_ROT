// ============================================================
// 1. БАЗОВОЕ РАЗРЕШЕНИЕ ИГРЫ
// ============================================================
global.base_width  = 1920;
global.base_height = 1080;

// ============================================================
// 2. НАСТРОЙКА ОКНА И ПОВЕРХНОСТИ
// ============================================================
window_set_size(global.base_width, global.base_height);
surface_resize(application_surface, global.base_width, global.base_height);

// ============================================================
// 3. НАСТРОЙКА GUI (интерфейс)
// ============================================================
display_set_gui_size(global.base_width, global.base_height);
// Если хотите, чтобы GUI растягивался на всё окно, используйте:
// display_set_gui_maximise();

// ============================================================
// 4. НАСТРОЙКА КАМЕРЫ (будет создана в Room Start)
// ============================================================
// Пока ничего, но можно инициализировать переменные
// (камера будет создана в Room Start)

// ============================================================
// 5. ОБЪЕКТ ПЕРСИСТЕНТНЫЙ (галочка в редакторе)
// ============================================================
// Убедитесь, что в редакторе объекта включена галочка "Persistent"
