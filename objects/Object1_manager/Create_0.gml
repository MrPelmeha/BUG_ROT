// ============================================================
// 1. БАЗОВОЕ РАЗРЕШЕНИЕ ИГРЫ
// ============================================================
global.base_width  = 1920;
global.base_height = 1080;

// ============================================================
// 2. НАСТРОЙКА ОКНА И ПОВЕРХНОСТИ
// ============================================================
window_set_size(global.base_width, global.base_height);
surface_resize(application_surface, global.base_width, global.base_height);

// ============================================================
// 3. НАСТРОЙКА GUI (интерфейс)
// ============================================================
display_set_gui_size(global.base_width, global.base_height);

// ============================================================
// 4. ПЕРЕМЕННЫЕ ДЛЯ ТАЙЛОВОЙ КАРТЫ (будут созданы в Room Start)
// ============================================================
global.tilemap = -1;
global.grid = -1;